{
  "name": "Vibrant Spectrum",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "focusBorder": "#277da1",
    "foreground": "#e9ecef",
    "widget.shadow": "#00000044",
    "selection.background": "#5775904d",
    "descriptionForeground": "#adb5bd",
    "errorForeground": "#f94144",
    "icon.foreground": "#ced4da",
    "window.activeBorder": "#2d2a2e",
    "window.inactiveBorder": "#2d2a2e",
    "textBlockQuote.background": "#363537",
    "textBlockQuote.border": "#277da1",
    "textCodeBlock.background": "#363537",
    "textLink.activeForeground": "#43aa8b",
    "textLink.foreground": "#277da1",
    "textPreformat.foreground": "#f9c74f",
    "textSeparator.foreground": "#6c757d",
    "button.background": "#277da1",
    "button.foreground": "#ffffff",
    "button.hoverBackground": "#577590",
    "dropdown.background": "#363537",
    "dropdown.listBackground": "#2d2a2e",
    "dropdown.border": "#495057",
    "dropdown.foreground": "#e9ecef",
    "input.background": "#2d2a2e",
    "input.border": "#495057",
    "input.foreground": "#e9ecef",
    "input.placeholderForeground": "#6c757d",
    "badge.foreground": "#ffffff",
    "badge.background": "#4d908e",
    "progressBar.background": "#f8961e",
    "titleBar.activeBackground": "#2d2a2e",
    "titleBar.activeForeground": "#e9ecef",
    "titleBar.inactiveBackground": "#2d2a2e",
    "titleBar.inactiveForeground": "#6c757d",
    "activityBar.background": "#2d2a2e",
    "activityBar.foreground": "#e9ecef",
    "activityBar.inactiveForeground": "#6c757d",
    "activityBarBadge.background": "#f94144",
    "activityBarBadge.foreground": "#ffffff",
    "activityBar.activeBorder": "#f9c74f",
    "sideBar.background": "#363537",
    "sideBar.foreground": "#ced4da",
    "sideBar.border": "#2d2a2e",
    "sideBarTitle.foreground": "#e9ecef",
    "sideBarSectionHeader.background": "#363537",
    "sideBarSectionHeader.foreground": "#e9ecef",
    "sideBarSectionHeader.border": "#2d2a2e",
    "list.inactiveSelectionBackground": "#495057",
    "list.inactiveSelectionForeground": "#e9ecef",
    "list.hoverBackground": "#49505780",
    "list.hoverForeground": "#e9ecef",
    "list.activeSelectionBackground": "#495057",
    "list.activeSelectionForeground": "#ffffff",
    "list.highlightForeground": "#f9c74f",
    "tab.activeBackground": "#363537",
    "tab.inactiveBackground": "#2d2a2e",
    "tab.activeForeground": "#e9ecef",
    "tab.inactiveForeground": "#6c757d",
    "tab.border": "#2d2a2e",
    "tab.activeBorderTop": "#f8961e",
    "editor.background": "#2d2a2e",
    "editor.foreground": "#f8f9fa",
    "editorLineNumber.foreground": "#6c757d",
    "editorCursor.foreground": "#f8961e",
    "editor.selectionBackground": "#5775904d",
    "editorWhitespace.foreground": "#495057",
    "editorIndentGuide.background1": "#495057",
    "editorIndentGuide.activeBackground1": "#6c757d",
    "editorBracketMatch.background": "#f8961e33",
    "editorBracketMatch.border": "#f8961e",
    "editorBracketHighlight.foreground1": "#ffd166",
    "editorBracketHighlight.foreground2": "#06D6A0",
    "editorBracketHighlight.foreground3": "#118AB2",
    "editorBracketHighlight.foreground4": "#EF476F",
    "editorBracketHighlight.foreground5": "#9B5DE5",
    "editorBracketHighlight.foreground6": "#F15BB5",
    "editorBracketPairGuide.activeBackground1": "#FFD16699",
    "editorBracketPairGuide.activeBackground2": "#06D6A099",
    "editorBracketPairGuide.activeBackground3": "#118AB299",
    "editorBracketPairGuide.activeBackground4": "#EF476F99",
    "editorBracketPairGuide.activeBackground5": "#9B5DE599",
    "editorBracketPairGuide.activeBackground6": "#F15BB599",
    "editorBracketPairGuide.background1": "#FFD16626",
    "editorBracketPairGuide.background2": "#06D6A026",
    "editorBracketPairGuide.background3": "#118AB226",
    "editorBracketPairGuide.background4": "#EF476F26",
    "editorBracketPairGuide.background5": "#9B5DE526",
    "editorBracketPairGuide.background6": "#F15BB526",
    "statusBar.background": "#363537",
    "statusBar.foreground": "#ced4da",
    "statusBar.border": "#2d2a2e",
    "statusBar.noFolderBackground": "#363537",
    "statusBar.debuggingBackground": "#f3722c"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6c757d",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#f94144"
      }
    },
    {
      "scope": [
        "variable",
        "variable.language",
        "variable.other",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#e9ecef"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "support.macro"
      ],
      "settings": {
        "foreground": "#f8961e"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#f9c74f"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string punctuation.section.embedded source"
      ],
      "settings": {
        "foreground": "#90be6d"
      }
    },
    {
      "scope": [
        "constant",
        "constant.numeric",
        "constant.language",
        "constant.other"
      ],
      "settings": {
        "foreground": "#277da1"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "support.type.property-name",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#f9844a"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#43aa8b"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#ced4da"
      }
    },
    {
      "scope": [
        "comment",
        "emphasis",
        "entity.name.method.js",
        "entity.name.class.js",
        "entity.name.tag.doctype",
        "entity.other.attribute-name",
        "entity.other.attribute-name.tag.jade",
        "entity.other.attribute-name.tag.pug",
        "keyword",
        "keyword.control",
        "keyword.operator.comparison",
        "keyword.control.flow.js",
        "keyword.control.flow.ts",
        "keyword.control.flow.tsx",
        "keyword.control.ruby",
        "keyword.control.module.ruby",
        "keyword.control.class.ruby",
        "keyword.control.def.ruby",
        "keyword.control.loop.js",
        "keyword.control.loop.ts",
        "keyword.control.import.js",
        "keyword.control.import.ts",
        "keyword.control.import.tsx",
        "keyword.control.from.js",
        "keyword.control.from.ts",
        "keyword.control.from.tsx",
        "keyword.operator.expression.delete",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.cast",
        "keyword.operator.relational",
        "keyword.operator.sizeof",
        "keyword.operator.logical.python",
        "italic",
        "markup.italic",
        "markup.quote",
        "markup.changed",
        "markup.italic.markdown",
        "markup.quote.markdown",
        "markup.deleted.diff",
        "markup.inserted.diff",
        "meta.delimiter.period",
        "meta.diff.header.git",
        "meta.diff.header.from-file",
        "meta.diff.header.to-file",
        "meta.tag.sgml.doctype",
        "meta.var.expr",
        "meta.class meta.method.declaration meta.var.expr storage.type.js",
        "meta.decorator punctuation.decorator",
        "meta.selector",
        "punctuation.accessor",
        "punctuation.definition.comment",
        "punctuation.definition.template-expression.begin",
        "punctuation.definition.template-expression.end",
        "punctuation.section.embedded",
        "quote",
        "source.js constant.other.object.key.js string.unquoted.label.js",
        "source.go keyword.package.go",
        "source.go keyword.import.go",
        "source.go keyword.function.go",
        "source.go keyword.type.go",
        "source.go keyword.struct.go",
        "source.go keyword.interface.go",
        "source.go keyword.const.go",
        "source.go keyword.var.go",
        "source.go keyword.map.go",
        "source.go keyword.channel.go",
        "source.go keyword.control.go",
        "storage",
        "storage.type",
        "storage.modifier",
        "storage.type.property.js",
        "storage.type.property.ts",
        "storage.type.property.tsx",
        "tag.decorator.js entity.name.tag.js",
        "tag.decorator.js",
        "text.html.basic entity.other.attribute-name.html",
        "text.html.basic entity.other.attribute-name",
        "variable.language",
        "variable.other.object.property"
      ],
      "settings": {
        "fontStyle": "italic"
      }
    }
  ]
}